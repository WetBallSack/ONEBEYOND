python3 -c "
import evdev
from evdev import ecodes
for path in evdev.list_devices():
    try:
        d = evdev.InputDevice(path)
        caps = d.capabilities()
        if ecodes.REL_X in caps.get(ecodes.EV_REL, []):
            print(path, '|', d.name, '|', d.phys)
        d.close()
    except: pass
"
